# API base URL (used at build time for Next.js).
#
# Local development: leave unset or use:
#   NEXT_PUBLIC_API_URL=http://localhost:3001
# If you point this at a production API (e.g. Render) while running the app on
# http://localhost:3000, the production server must list that origin in
# ALLOWED_ORIGINS or the browser will block requests with a CORS error.
#
# Production / Vercel: set to your deployed Rails API URL (https://...).
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com
